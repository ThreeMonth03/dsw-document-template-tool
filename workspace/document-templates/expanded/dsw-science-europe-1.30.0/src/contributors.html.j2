{%- set contributorsPath = [uuids.adminDetailsCUuid, uuids.contributorsQUuid]|join(".") -%}
{%- set contributorsItems = repliesMap[contributorsPath]|reply_items -%}
<div id="dmp-contributors">
  {# __tr_block_0000:start #}<h2>Contributors</h2>{# __tr_block_0000:end #}

  {# __tr_block_0001:start #}<p>The following contributors are related to the {{globals.projects}} of this DMP:</p>{# __tr_block_0001:end #}

  {% set contributors = [] %}
  {%- for contributor in contributorsItems -%}
    {%- set pathPrefix = [contributorsPath, contributor]|reply_path ~ "." -%}
    {%- set contributorName = repliesMap[pathPrefix ~ uuids.contributorNameQUuid]|reply_str_value -%}
    {%- set contributorEmail = repliesMap[pathPrefix ~ uuids.contributorEmailQUuid]|reply_str_value -%}
    {%- set contributorOrcid = repliesMap[pathPrefix ~ uuids.contributorOrcidQUuid] -%}
    {%- set contributorRoles = repliesMap[pathPrefix ~ uuids.contributorRoleQUuid]|reply_items -%}
    {%- set contributorAffiliationReply = repliesMap[pathPrefix ~ uuids.contributorAffiliationQUuid] -%}
    {%- if contributorName -%}
      {%- set roles = [] -%}
      {%- for role in contributorRoles -%}
        {%- if role in dc.e.choices.keys() -%}
          {%- do roles.append(dc.e.choices[role].label) -%}
        {%- endif -%}
      {%- endfor -%}
      {%- do contributors.append({
        'name': contributorName,
        'email': contributorEmail,
        'orcid': contributorOrcid,
        'roles': roles|sort,
        'affiliation': contributorAffiliationReply,
      }) -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if contributors|length > 0 -%}
  <ul>
  {% for contributor in contributors %}
    {# __tr_branch_sentence_original:PGxpIGNsYXNzPSJjb250cmlidXRvciI-CiAgICAgIDxzcGFuIGNsYXNzPSJuYW1lIj48c3Ryb25nPnt7IGNvbnRyaWJ1dG9yLm5hbWUgfX08L3N0cm9uZz48L3NwYW4-CiAgICAgIHslLSBpZiBjb250cmlidXRvci5lbWFpbCBhbmQgY29udHJpYnV0b3Iub3JjaWQgJX0KICAgICAgICA8YnI---CiAgICAgIHslLSBlbmRpZiAlfQogICAgPC9saT4= #}{# __tr_block_0002:start #}<li class="contributor">
      <span class="name"><strong>{{ contributor.name }}</strong></span>
      {%- if contributor.email and contributor.orcid %}
        <br>{{ macros.formatEmail(contributor.email) }}, {{ macros.formatOrcid(contributor.orcid) }}
      {%- elif contributor.email %}
        <br>{{ macros.formatEmail(contributor.email) }}
      {%- elif contributor.orcid %}
        <br>{{ macros.formatOrcid(contributor.orcid) }}
      {%- endif -%}
      {%- if contributor.roles|length > 0 %}{% if contributor.roles|length == 0 %}
        <br>Role: {% for role in contributor.roles %}<span class="role">{{ role }}</span>{% if not loop.last %}, {% endif %}{% endfor %}
      {% else %}
        <br>Roles: {% for role in contributor.roles %}<span class="role">{{ role }}</span>{% if not loop.last %}, {% endif %}{% endfor %}
      {% endif %}{%- endif %}
      {%- if contributor.affiliation %}
        <br>Affiliation: <span class="affiliation">{{ macros.integrationROR(contributor.affiliation) }}</span>
      {%- endif %}
    </li>{# __tr_block_0002:end #}{# __tr_branch_sentence_original:end #}
  {% endfor %}
  </ul>
  {%- elif dc.project.created_by -%}
  <ul>
    {# __tr_block_0003:start #}<li class="contributor">
      <span class="name">{{ dc.project.created_by.first_name }} {{ dc.project.created_by.last_name }}</span>
      <br>{{ macros.formatEmail(dc.project.created_by.email) }}
      {%- if dc.project.created_by.affiliation %}
      <br>Affiliation: <span class="affiliation">{{ dc.project.created_by.affiliation }}</span>
      {%- endif %}
    </li>{# __tr_block_0003:end #}
  </ul>
  {%- else -%}
  <div style="font-style:italic;">{# __tr_block_0004:start #}There are no contributors described for this DMP.{# __tr_block_0004:end #}</div>
  {%- endif -%}
</div>
