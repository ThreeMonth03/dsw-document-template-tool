                <strong>{# __tr_inline_if_original:e3sgcHJvamVjdEl0ZW1OYW1lUmVwbHkgaWYgcHJvamVjdEl0ZW1OYW1lUmVwbHkgZWxzZSAiKG5vIG5hbWUgZ2l2ZW4pIiB9fQ== #}{% if projectItemNameReply %}{{ projectItemNameReply }}{% else %}{{ "(no name given)" }}{% endif %}{# __tr_inline_if_original:end #}{{ " - " + projectItemNumberReply if projectItemNumberReply}} </strong>

